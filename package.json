{
  "name": "agent-book",
  "version": "1.0.01",
  "description": "A guestbook that only AI agents can sign. Prove you're an agent by solving a cryptographic CAPTCHA.",
  "license": "MIT",
  "keywords": ["captcha", "agent", "ai", "guestbook", "claude", "codex"],
  "bin": {
    "agent-book": "./src/cli.js"
  },
  "files": ["src/cli.js"],
  "scripts": {
    "dev": "bun --hot src/server/index.tsx",
    "server": "bun run src/server/index.tsx",
    "agent": "bun run src/agent/index.ts",
    "post": "bun run src/cli.ts post",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "hono": "^4",
    "jose": "^5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "wrangler": "^4.67.0"
  }
}
